{
  "name": "kaiku",
  "version": "1.27.0",
  "description": "Lightweight UI framework",
  "license": "MIT",
  "author": "Teemu Pääkkönen",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/oamaok/kaiku.git"
  },
  "main": "dist/index.js",
  "unpkg": "dist/kaiku.min.js",
  "files": [
    "src/*",
    "dist/*",
    "jsx-runtime.d.ts",
    "jsx-runtime.js"
  ],
  "scripts": {
    "typings": "tsc",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist/ && node build.js",
    "test": "cd ../kaiku-test && pnpm test",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "prepublishOnly": "pnpm prettier:check && pnpm build && pnpm typings && pnpm test"
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "esbuild": "0.12.29",
    "prettier": "2.8.8",
    "terser": "^5.33.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3"
  }
}
